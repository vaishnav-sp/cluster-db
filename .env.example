# Application Environment
APP_ENV=development

# Server Configuration
SERVER_PORT=9090
SERVER_HOST=0.0.0.0
SERVER_GRPC_PORT=9091

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Node Configuration
NODE_ID=node-1
NODE_NAME=atlasdb-node-1
CLUSTER_NAME=cluster-1

# Security
JWT_SECRET=your-secret-key-here-change-in-production
TLS_ENABLED=false
TLS_CERT_PATH=/etc/atlasdb/certs/server.crt
TLS_KEY_PATH=/etc/atlasdb/certs/server.key

# Database Configuration
DB_PATH=/var/lib/atlasdb/data
DB_WAL_PATH=/var/lib/atlasdb/wal
DB_CACHE_SIZE=1073741824

# Cluster Configuration
CLUSTER_PEERS=localhost:9091,localhost:9092,localhost:9093
CLUSTER_HEARTBEAT_INTERVAL=100ms
CLUSTER_ELECTION_TIMEOUT=300ms

# Replication
REPLICATION_FACTOR=3
SYNC_REPLICATION=true

# Storage
STORAGE_ENGINE=lsm
STORAGE_BLOCK_SIZE=4096
STORAGE_COMPRESSION=snappy

# Cache
CACHE_ENABLED=true
CACHE_SIZE=1073741824

# Redis (Optional)
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Monitoring
METRICS_ENABLED=true
METRICS_PORT=9092
PROMETHEUS_ENABLED=true

# Tracing (Optional)
TRACING_ENABLED=false
JAEGER_ENDPOINT=http://localhost:14268/api/traces

# LLAMA/OLLAMA Integration (Optional)
OLLAMA_ENABLED=false
OLLAMA_URL=http://localhost:11434

# Development
DEBUG=false
PROFILE=false
PPROF_ENABLED=false

# Timeouts (in seconds)
READ_TIMEOUT=30
WRITE_TIMEOUT=30
IDLE_TIMEOUT=60

# Connection Pool
MAX_CONNECTIONS=100
MIN_IDLE_CONNECTIONS=10

# Backup
BACKUP_ENABLED=false
BACKUP_INTERVAL=86400
BACKUP_PATH=/var/lib/atlasdb/backups
