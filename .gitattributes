# Auto detect text files and normalize line endings to LF
* text=auto

# Go files
*.go text eol=lf
go.mod text eol=lf
go.sum text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf
*.zsh text eol=lf

# Windows batch files
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Dockerfiles
Dockerfile text eol=lf
*.dockerfile text eol=lf

# YAML configuration
*.yml text eol=lf
*.yaml text eol=lf

# Markdown
*.md text eol=lf
*.markdown text eol=lf

# JSON
*.json text eol=lf

# Makefiles
Makefile text eol=lf
makefile text eol=lf

# Protocol Buffers
*.proto text eol=lf

# SQL
*.sql text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary
*.mp3 binary
*.gz binary
*.zip binary
*.7z binary
*.ttf binary
*.otf binary

# Archives
*.tar export-ignore
*.tar.gz export-ignore
*.zip export-ignore
